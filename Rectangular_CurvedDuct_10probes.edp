// File for probe point summary (easy reading)
ofstream probeSummary("ProbeSummary.txt");
probeSummary << "# PROBE POINTS SUMMARY" << endl;
probeSummary << "# ID | X | Y | Name | Description" << endl;
for(int i=0; i<nProbes; i++) {
    probeSummary << i+1 << " | " << probeX[i] << " | " << probeY[i]
                 << " | " << probeName[i] << " | " << probeDesc[i] << endl;
}


// ======================================================================
// TECPLOT ASCII CONTOUR FILE
// (velocity, streamline/Psi, vorticity/Zeta, isotherm/Theta,
//  axial velocity/W, secondary velocity U,V,Mag, KE, entropy, Bejan)
// ======================================================================
ofstream tecFile("CurvedDuct_AllFields_Tecplot.dat");
tecFile << "TITLE = \"Curved Duct - All Fields\"" << endl;
tecFile << "VARIABLES = \"X\",\"Y\",\"W\",\"Psi\",\"Zeta\",\"Theta\",\"U\",\"V\",\"Mag\",\"KE\",\"NsTotal\",\"Be\"" << endl;

// ======================================================================
// FUNCTION TO INTERPOLATE VALUES AT PROBE POINTS
// ======================================================================

func int updateProbePoints() {
    for(int i=0; i<nProbes; i++) {
        real xx = probeX[i];
        real yy = probeY[i];

        Wprobe[i] = W(xx, yy);
        Psiprobe[i] = Psi(xx, yy);
        Thetaprobe[i] = Theta(xx, yy);
        Uprobe[i] = U(xx, yy);
        Vprobe[i] = V(xx, yy);
        Magprobe[i] = sqrt(Uprobe[i]^2 + Vprobe[i]^2);
        KEprobe[i] = KE(xx, yy);
        NsThermalProbe[i] = NsThermal(xx, yy);
        NsFrictionProbe[i] = NsFriction(xx, yy);
        NsTotalProbe[i] = NsTotal(xx, yy);
        BeProbe[i] = BeLocal(xx, yy);
    }
    return 0;
}

// ======================================================================
// FUNCTION TO UPDATE TIME AVERAGES
// ======================================================================

func int updateTimeAverages() {
    for(int i=0; i<nProbes; i++) {
        WprobeAvg[i] += Wprobe[i];
        PsiprobeAvg[i] += Psiprobe[i];
        ThetaprobeAvg[i] += Thetaprobe[i];
        UprobeAvg[i] += Uprobe[i];
        VprobeAvg[i] += Vprobe[i];
        MagprobeAvg[i] += Magprobe[i];
        KEprobeAvg[i] += KEprobe[i];
        NsTotalProbeAvg[i] += NsTotalProbe[i];
        BeProbeAvg[i] += BeProbe[i];
    }
    return 0;
}

