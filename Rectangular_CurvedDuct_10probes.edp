probeFile10 << "# Time W Psi Theta U V Mag KE NsTh NsFr NsTot Be" << endl;

// File for time-averaged probe data
ofstream probeAvgData("ProbeData_TimeAveraged.txt");
probeAvgData << "# Time-Averaged Data (t = " << sampleStart << " to " << tmax << ")" << endl;
probeAvgData << "# ID Name X Y Description W_avg Psi_avg Theta_avg U_avg V_avg Mag_avg KE_avg NsTot_avg Be_avg" << endl;

// File for centerline profile (X-direction at Y=0)
ofstream centerlineProfile("CenterlineProfile.txt");
centerlineProfile << "# X Y W Psi Theta U V Mag KE NsTot Be" << endl;

// File for vertical line profile (Y-direction at X=0)
