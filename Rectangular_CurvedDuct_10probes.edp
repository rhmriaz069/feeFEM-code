// ======================================================================
// FUNCTION TO WRITE PROFILES
// ======================================================================

func int writeProfiles(real time) {
    // Centerline profile (Y=0, X from -1 to 1)
    centerlineProfile << "# Profile at t = " << time << endl;
    for(real x=-1.0; x<=1.0; x+=0.05) {
        real y = 0.0;
        centerlineProfile << x << " " << y << " "
                         << W(x,y) << " " << Psi(x,y) << " "
                         << Theta(x,y) << " " << U(x,y) << " "
                         << V(x,y) << " " << sqrt(U(x,y)^2+V(x,y)^2) << " "
                         << KE(x,y) << " " << NsTotal(x,y) << " " << BeLocal(x,y) << endl;
    }
    centerlineProfile << endl << endl;

    // Vertical profile (X=0, Y from -1 to 1)
    verticalProfile << "# Profile at t = " << time << endl;
    for(real y=-1.0; y<=1.0; y+=0.05) {
        real x = 0.0;
        verticalProfile << x << " " << y << " "
                       << W(x,y) << " " << Psi(x,y) << " "
                       << Theta(x,y) << " " << U(x,y) << " "
                       << V(x,y) << " " << sqrt(U(x,y)^2+V(x,y)^2) << " "
                       << KE(x,y) << " " << NsTotal(x,y) << " " << BeLocal(x,y) << endl;
    }
    verticalProfile << endl << endl;
    return 0;
}

// ======================================================================
// FUNCTION TO WRITE A TECPLOT ZONE (ALL FIELDS, FE TRIANGLE MESH)
// ======================================================================

func int writeTecplotZone(real time) {
    tecFile << "ZONE T=\"t=" << time << "\", SOLUTIONTIME=" << time
            << ", STRANDID=1, NODES=" << Th.nv << ", ELEMENTS=" << Th.nt
            << ", DATAPACKING=POINT, ZONETYPE=FETRIANGLE" << endl;
    for(int i=0; i<Th.nv; i++) {
        tecFile << Th(i).x << " " << Th(i).y << " "
                << W[][i] << " " << Psi[][i] << " " << Zeta[][i] << " "
                << Theta[][i] << " " << U[][i] << " " << V[][i] << " "
                << Mag[][i] << " " << KE[][i] << " " << NsTotal[][i] << " "
                << BeLocal[][i] << endl;
    }
    for(int k=0; k<Th.nt; k++) {
        tecFile << Th[k][0]+1 << " " << Th[k][1]+1 << " " << Th[k][2]+1 << endl;
    }
    return 0;
}

// ======================================================================
// FUNCTION TO PRINT PROBE VALUES TO SCREEN
// ======================================================================

func int printProbeValues(real time) {
    cout << "\n========== PROBE POINT VALUES at t = " << time << " ==========" << endl;
    cout << "ID  Name    X     Y     W        Psi      Theta    U        V        Mag      KE       NsTot    Be" << endl;
    cout << "-----------------------------------------------------------------------------------------------" << endl;
    for(int i=0; i<nProbes; i++) {
        cout << i+1 << "  " << probeName[i] << "  "
             << probeX[i] << " " << probeY[i] << "  "
             << Wprobe[i] << " " << Psiprobe[i] << " " << Thetaprobe[i] << " "
             << Uprobe[i] << " " << Vprobe[i] << " " << Magprobe[i] << " "
             << KEprobe[i] << " " << NsTotalProbe[i] << " " << BeProbe[i] << endl;
    }
    cout << "=================================================================================================" << endl;
    return 0;
}

// ======================================================================
// TIME LOOP
// ======================================================================

int nsteps = floor(tmax/dt);
real Wmean, lambda, NuAvg, PsiMax, SecMax, NuIn, NuOut;
real WmaxVal, TmaxVal;
real KEtot, SgenThermalTot, SgenFrictionTot, SgenTotalGlobal, BeAvgGlobal;
real Area;

cout << "\n=========================================================" << endl;
cout << "STARTING TIME INTEGRATION" << endl;
cout << "=========================================================" << endl;
cout << "Total steps: " << nsteps << ", dt = " << dt << endl;
cout << "Number of probe points: " << nProbes << endl;
cout << "Averaging starts at t = " << sampleStart << endl;
cout << "=========================================================" << endl;

for(int step=0; step<=nsteps; step++)
{
    real time = step*dt;

    Wk     = Wold;
    PsiK   = PsiOld;
    ZetaK  = ZetaOld;
    ThetaK = ThetaOld;

    for(int iter=0; iter<20; iter++)
    {
        // ==============================================================
//                 AXIAL VELOCITY EQUATION
// ==============================================================
solve Axial(W, phi, solver=UMFPACK) =
    int2d(Th)( (1.0+delta*x)/dt * W * phi
             + (1.0+delta*x) * (dx(W)*dx(phi) + dy(W)*dy(phi))
             + (dy(PsiK)*dx(W) - dx(PsiK)*dy(W)) * phi
             + (delta/(1.0+delta*x)) * dy(PsiK) * W * phi
             - delta* dx(W)* phi   
             + (delta*delta/(1.0+delta*x)) * W * phi )
  - int2d(Th)( (1.0+delta*x)/dt * Wold * phi + Dn * phi )
  + on(1,2,3,4, W=0);

// ==============================================================
//                        VORTICITY EQUATION  
// ==============================================================
solve Vorticity(Zeta, phi, solver=UMFPACK) =
    int2d(Th)( (1.0+delta*x)/dt * Zeta * phi
             + (dx(Zeta)*dy(PsiK) - dy(Zeta)*dx(PsiK)) * phi
             - (delta/(1.0+delta*x)) * dy(PsiK) * Zeta * phi
             + (1.0+delta*x) * (dx(Zeta)*dx(phi) + dy(Zeta)*dy(phi))
             + (delta*delta/(1.0+delta*x)) * Zeta * phi )
  + int2d(Th) (delta* dx(Zeta)* phi)
  - int2d(Th)( (1.0+delta*x)/dt * ZetaOld * phi
             - Wk * dy(Wk) * phi
             + (1.0+delta*x) * Gr * dx(ThetaK) * phi )
  + on(1,2,3,4, Zeta = ZetaWallThom(x,y));
  
// ==============================================================
//                      STREAM FUNCTION
// ==============================================================
solve Stream(Psi, phi, solver=UMFPACK) =
    int2d(Th)( dx(Psi)*dx(phi) + dy(Psi)*dy(phi)
             + (delta/(1.0+delta*x)) * dx(Psi) * phi )
  - int2d(Th)( (1.0+delta*x) * Zeta * phi )
  + on(1,2,3,4, Psi=0);

// ==============================================================
//                        ENERGY EQUATION
// ==============================================================
solve Energy(Theta, phi, solver=UMFPACK) =
    int2d(Th)( (1.0/dt) * Theta * phi
             + (1.0/(1.0+delta*x)) * (dy(PsiK)*dx(Theta) - dx(PsiK)*dy(Theta)) * phi
             + (1.0/Pr) * (dx(Theta)*dx(phi) + dy(Theta)*dy(phi))
             - (1.0/Pr) * (delta/(1.0+delta*x)) * dx(Theta) * phi )
  - int2d(Th)( (1.0/dt) * ThetaOld * phi )
  + on(4, Theta = 1)
  + on(2, Theta = 0);


 // ==============================================================
 // CONVERGENCE CHECK
 // ==============================================================
        real errW = sqrt(int2d(Th)( (W-Wk)^2 ));
        real errP = sqrt(int2d(Th)( (Psi-PsiK)^2 ));
        real errT = sqrt(int2d(Th)( (Theta-ThetaK)^2 ));
        real err = max(errW, max(errP, errT));
		
        if (err != err || err > 1.0e6) {   // err!=err catches NaN
            cout << "\n!!! DIVERGENCE DETECTED at t=" << time << ", iter=" << iter
                 << ", err=" << err << " -- stopping run. !!!" << endl;
            cout << "    Try: smaller dt, smaller relax/relaxWall, or check Dn/Gr/Pr." << endl;
            exit(1);
        }

        Wk[]     = relax * W[] + (1.-relax) * Wk[];
        PsiK[]   = relax * Psi[] + (1.-relax) * PsiK[];
        ZetaK[]  = relax * Zeta[] + (1.-relax) * ZetaK[];
        ThetaK[] = relax * Theta[] + (1.-relax) * ThetaK[];

        if(err < tol) break;
    }

    Wold     = W;
    PsiOld   = Psi;
    ZetaOld  = Zeta;
    ThetaOld = Theta;

    // ==============================================================
    // SECONDARY FLOW VELOCITIES  (UNCHANGED)
    // ==============================================================
    U = (1.0/(1.0+delta*x)) * dy(Psi);
    V = -(1.0/(1.0+delta*x)) * dx(Psi);
    Mag = sqrt(U^2 + V^2);

    // ==============================================================
    // NUSSELT NUMBERS  (UNCHANGED)
    // ==============================================================
    NuIn  = 0.5 * int1d(Th,4)( -dx(Theta) );
    NuOut = 0.5 * int1d(Th,2)( -dx(Theta) );

    // ==============================================================
    // MEAN AXIAL VELOCITY AND HYDRAULIC RESISTANCE COEFFICIENT
    // (UNCHANGED, lambda is the friction/hydraulic resistance
    // ==============================================================
    Area = int2d(Th)(1.0);
    Wmean = int2d(Th)(W) / Area;
    lambda = (4.0 * sqrt(2.0*delta) * Dn) / (Wmean * Wmean);
    NuAvg = 0.5 * (NuIn + abs(NuOut));

    WmaxVal = W[].max;
    TmaxVal = Theta[].max;
    PsiMax  = Psi[].max;
    SecMax  = Mag[].max;

    // ==============================================================
    // POST-PROCESSING: KINETIC ENERGY FIELD
    // ==============================================================
    KE = 0.5 * (U^2 + V^2);
    KEtot = int2d(Th)( KE );  // domain-integrated (total) kinetic energy

    // ==============================================================
    // POST-PROCESSING: LOCAL ENTROPY GENERATION AND BEJAN NUMBER
    // ==============================================================
	
    NsThermal  = dx(Theta)^2 + dy(Theta)^2;
    NsFriction = Phi * ( 2.0*dx(U)^2 + 2.0*delta*delta*U^2/(1.0+delta*x)^2 + 2.0*dy(V)^2
                        + (dy(U)+dx(V))^2
                        + (1.0/(2.0*delta)) * ( (dx(W) - delta*W/(1.0+delta*x))^2 + dy(W)^2 ) );
    NsTotal    = NsThermal + NsFriction;
    BeLocal    = NsThermal / (NsTotal + 1.0e-12);  // small eps avoids /0

    SgenThermalTot  = int2d(Th)( NsThermal );
    SgenFrictionTot = int2d(Th)( NsFriction );
    SgenTotalGlobal = SgenThermalTot + SgenFrictionTot;

    // ==============================================================
    //  WALL SHEAR STRESS / SKIN FRICTION
    // ==============================================================
    real tauAxialInner  = int1d(Th,4)( -dx(W) ) / int1d(Th,4)(1.0);   // x=-1
    real tauAxialOuter  = int1d(Th,2)(  dx(W) ) / int1d(Th,2)(1.0);   // x=+1
    real tauAxialBottom = int1d(Th,1)( -dy(W) ) / int1d(Th,1)(1.0);   // y=-1
    real tauAxialTop    = int1d(Th,3)(  dy(W) ) / int1d(Th,3)(1.0);   // y=+1
    real tauSecInner    = int1d(Th,4)( -dx(V) ) / int1d(Th,4)(1.0);   // wall-tangential = V on x=const walls
    real tauSecOuter    = int1d(Th,2)(  dx(V) ) / int1d(Th,2)(1.0);
    real tauSecBottom   = int1d(Th,1)( -dy(U) ) / int1d(Th,1)(1.0);   // wall-tangential = U on y=const walls
    real tauSecTop      = int1d(Th,3)(  dy(U) ) / int1d(Th,3)(1.0);
    BeAvgGlobal     = SgenThermalTot / (SgenTotalGlobal + 1.0e-12);

    // ==============================================================
    // UPDATE PROBE POINTS DATA
    // ==============================================================
    updateProbePoints();

    // ==============================================================
    // WRITE INSTANTANEOUS PROBE DATA (EVERY SINGLE TIME STEP)
    // ==============================================================
    writeProbeData(time);

    // ==============================================================
    // WRITE PROFILES (every 200 steps)
    // ==============================================================
    if(step % 1 == 0 && step > 0) {
        writeProfiles(time);
        writeTecplotZone(time);
    }

    // ==============================================================
    // TIME AVERAGING
    // ==============================================================
    if(time >= sampleStart) {
        NuInSum    += NuIn;
        NuOutSum   += NuOut;
        WmeanSum   += Wmean;
        KEtotSum   += KEtot;
        lambdaSum  += lambda;
        SgenTotSum += SgenTotalGlobal;
        BeAvgSum   += BeAvgGlobal;
        updateTimeAverages();
        sampleCount++;
    }

    // ==============================================================
    // WRITE GLOBAL DATA (single merged per-timestep file)
    // ==============================================================
    timeStepData << time << " "
                 << WmaxVal << " " << PsiMax << " " << SecMax << " "
                 << NuIn << " " << NuOut << " " << NuAvg << " "
                 << lambda << " " << Wmean << " "
                 << KEtot << " " << SgenThermalTot << " " << SgenFrictionTot << " "
                 << SgenTotalGlobal << " " << BeAvgGlobal << " "
                 << tauAxialInner << " " << tauAxialOuter << " " << tauAxialBottom << " " << tauAxialTop << " "
                 << tauSecInner << " " << tauSecOuter << " " << tauSecBottom << " " << tauSecTop << endl;

    // ==============================================================
    // SCREEN OUTPUT WITH PROBE POINTS
    // ==============================================================
    if(step % 100 == 0)
    {
        cout << "\n---------------------------------------------------------" << endl;
        cout << "t = " << time << " | Step = " << step << " of " << nsteps << endl;
        cout << "---------------------------------------------------------" << endl;
        cout << "Wmax = " << WmaxVal << " | PsiMax = " << PsiMax << " | SecMax = " << SecMax << endl;
        cout << "NuIn = " << NuIn << " | NuOut = " << NuOut << " | NuAvg = " << NuAvg << endl;
        cout << "Lambda = " << lambda << " | Wmean = " << Wmean << endl;
        cout << "KEtot = " << KEtot << " | SgenTot = " << SgenTotalGlobal << " | BeAvg = " << BeAvgGlobal << endl;
        cout << "---------------------------------------------------------" << endl;
        cout << "KEY PROBE POINTS:" << endl;
        cout << "  P03 (Center)       : W = " << Wprobe[2] << ", Theta = " << Thetaprobe[2] << ", Be = " << BeProbe[2] << endl;
        cout << "  P01 (Inner Wall)   : W = " << Wprobe[0] << ", Theta = " << Thetaprobe[0] << ", Be = " << BeProbe[0] << endl;
        cout << "  P05 (Outer Wall)   : W = " << Wprobe[4] << ", Theta = " << Thetaprobe[4] << ", Be = " << BeProbe[4] << endl;
        cout << "  P08 (Inner Vortex) : W = " << Wprobe[7] << ", KE = " << KEprobe[7] << endl;
        cout << "  P10 (Outer Vortex) : W = " << Wprobe[9] << ", KE = " << KEprobe[9] << endl;
        cout << "---------------------------------------------------------" << endl;

        // ==========================================================
        // LIVE PLOT WINDOWS (one field per window, updated live)
        // ==========================================================
        plot(W,        fill=1, value=1, nbiso=20, wait=0, WindowIndex=0, cmm="Axial Velocity W, t="+time);
        plot(Psi,      fill=1, value=1, nbiso=20, wait=0, WindowIndex=1, cmm="Stream Function Psi, t="+time);
        plot(Zeta,     fill=1, value=1, nbiso=20, wait=0, WindowIndex=2, cmm="Vorticity Zeta, t="+time);
        plot(Theta,    fill=1, value=1, nbiso=20, wait=0, WindowIndex=3, cmm="Temperature Theta, t="+time);
        plot(Mag,      fill=1, value=1, nbiso=20, wait=0, WindowIndex=4, cmm="Secondary Flow Magnitude, t="+time);
        plot(KE,       fill=1, value=1, nbiso=20, wait=0, WindowIndex=5, cmm="Kinetic Energy, t="+time);
        plot(NsTotal,  fill=1, value=1, nbiso=20, wait=0, WindowIndex=6, cmm="Total Entropy Generation, t="+time);
        plot(BeLocal,  fill=1, value=1, nbiso=20, wait=0, WindowIndex=7, cmm="Bejan Number, t="+time);
        plot([U,V],    coef=0.05, wait=0, WindowIndex=8, cmm="Secondary Flow Vectors, t="+time);
    }

    // Print full probe table every 500 steps
    if(step % 500 == 0 && step > 0) {
        printProbeValues(time);
    }
}

// ======================================================================
// COMPUTE TIME-AVERAGED PROBE DATA
// ======================================================================

if(sampleCount > 0) {
    for(int i=0; i<nProbes; i++) {
        WprobeAvg[i] /= sampleCount;
        PsiprobeAvg[i] /= sampleCount;
        ThetaprobeAvg[i] /= sampleCount;
        UprobeAvg[i] /= sampleCount;
        VprobeAvg[i] /= sampleCount;
        MagprobeAvg[i] /= sampleCount;
        KEprobeAvg[i] /= sampleCount;
        NsTotalProbeAvg[i] /= sampleCount;
        BeProbeAvg[i] /= sampleCount;
    }
}

// Write time-averaged probe data
for(int i=0; i<nProbes; i++) {
    probeAvgData << i+1 << " "
                 << probeName[i] << " "
                 << probeX[i] << " "
                 << probeY[i] << " "
                 << probeDesc[i] << " "
                 << WprobeAvg[i] << " "
                 << PsiprobeAvg[i] << " "
                 << ThetaprobeAvg[i] << " "
                 << UprobeAvg[i] << " "
                 << VprobeAvg[i] << " "
                 << MagprobeAvg[i] << " "
                 << KEprobeAvg[i] << " "
                 << NsTotalProbeAvg[i] << " "
                 << BeProbeAvg[i] << endl;
}

// ======================================================================
// FINAL TIME-AVERAGED RESULTS
// ======================================================================

real NuInAvg, NuOutAvg, WmeanAvg, lambdaAvg, NuAvgAvg;
real KEtotAvg, SgenTotAvg, BeAvgFinal;

if (sampleCount > 0) {
    NuInAvg    = NuInSum / sampleCount;
    NuOutAvg   = NuOutSum / sampleCount;
    WmeanAvg   = WmeanSum / sampleCount;
    KEtotAvg   = KEtotSum / sampleCount;
    SgenTotAvg = SgenTotSum / sampleCount;
    BeAvgFinal = BeAvgSum / sampleCount;
} else {
    cout << "WARNING: sampleCount=0. Using final-step values instead." << endl;
    NuInAvg    = NuIn;
    NuOutAvg   = NuOut;
    WmeanAvg   = Wmean;
    KEtotAvg   = KEtot;
    SgenTotAvg = SgenTotalGlobal;
    BeAvgFinal = BeAvgGlobal;
}

lambdaAvg = (4.0 * sqrt(2.0*delta) * Dn) / (WmeanAvg * WmeanAvg);
NuAvgAvg  = 0.5 * (NuInAvg + abs(NuOutAvg));

// ======================================================================
// FINAL OUTPUT
// ======================================================================

cout << "\n\n";
cout << "################################################################" << endl;
cout << "                    SIMULATION COMPLETED                        " << endl;
cout << "################################################################" << endl;
cout << "\n========== TIME-AVERAGED PERFORMANCE PARAMETERS ==========" << endl;
cout << "Averaging period: t = " << sampleStart << " to " << tmax << endl;
cout << "Number of samples: " << sampleCount << endl;
cout << "-----------------------------------------------------------" << endl;
cout << "Mean axial velocity         <W>     = " << WmeanAvg << endl;
cout << "Hydraulic resistance coeff  lambda  = " << lambdaAvg << endl;
cout << "Inner Nusselt number        NuIn    = " << NuInAvg << endl;
cout << "Outer Nusselt number        NuOut   = " << NuOutAvg << endl;
cout << "Average Nusselt number      NuAvg   = " << NuAvgAvg << endl;
cout << "Total kinetic energy        KEtot   = " << KEtotAvg << endl;
cout << "Total entropy generation    Sgen    = " << SgenTotAvg << endl;
cout << "Average Bejan number        Be      = " << BeAvgFinal << endl;
cout << "-----------------------------------------------------------" << endl;

cout << "\n========== TIME-AVERAGED PROBE POINT DATA ==========" << endl;
cout << "ID  Name    X     Y     Description            W_avg     Theta_avg   KE_avg    Be_avg" << endl;
cout << "-----------------------------------------------------------------------------------" << endl;
for(int i=0; i<nProbes; i++) {
    cout << i+1 << "  " << probeName[i] << "  "
         << probeX[i] << " " << probeY[i] << "  "
         << probeDesc[i] << " "
         << WprobeAvg[i] << "  " << ThetaprobeAvg[i] << "  "
         << KEprobeAvg[i] << "  " << BeProbeAvg[i] << endl;
}
cout << "=========================================================" << endl;

// ======================================================================
// SAVE VTK
// ======================================================================

savevtk("CurvedDuct_solution.vtu", Th, W, Psi, Zeta, Theta, U, V, Mag, KE, NsTotal, BeLocal,
        dataname="AxialVelocity StreamFunction Vorticity Temperature Uvelocity Vvelocity SecondaryMagnitude KineticEnergy EntropyGenTotal BejanNumber");

// ======================================================================
// WRITE FINAL TECPLOT ZONE (converged / last time step)
// ======================================================================

writeTecplotZone(tmax);

// ======================================================================
// SAVE FINAL DATA
// ======================================================================

ofstream finalData("final_solution_data.txt");
finalData << "# Final solution parameters" << endl;
finalData << "Dn = " << Dn << endl;
finalData << "Gr = " << Gr << endl;
finalData << "Pr = " << Pr << endl;
finalData << "delta = " << delta << endl;
finalData << "Phi (irreversibility ratio) = " << Phi << endl;
finalData << "Wmean = " << WmeanAvg << endl;
finalData << "Lambda = " << lambdaAvg << endl;
finalData << "NuIn = " << NuInAvg << endl;
finalData << "NuOut = " << NuOutAvg << endl;
finalData << "NuAvg = " << NuAvgAvg << endl;
finalData << "KEtot_avg = " << KEtotAvg << endl;
finalData << "SgenTot_avg = " << SgenTotAvg << endl;
finalData << "BeAvg = " << BeAvgFinal << endl;
finalData << "Wcenter_avg = " << WprobeAvg[2] << endl;
finalData << "Tcenter_avg = " << ThetaprobeAvg[2] << endl;
finalData << "W_inner_wall_avg = " << WprobeAvg[0] << endl;
finalData << "W_outer_wall_avg = " << WprobeAvg[4] << endl;

cout << "\n========== OUTPUT FILES GENERATED ==========" << endl;
cout << "1. TimeStepData.txt              - ALL per-timestep global data in ONE file" << endl;
cout << "                                    (Wmax, PsiMax, SecMax, NuIn, NuOut, NuAvg," << endl;
cout << "                                     Lambda, Wmean, KEtot, SgenThermal, SgenFriction," << endl;
cout << "                                     SgenTotal, BeAvg)" << endl;
cout << "2. Probe_P01..P10_*.txt           - 10 SEPARATE files, one per probe point," << endl;
cout << "                                    each with EVERY time step (t=0,0.005,0.010,...)" << endl;
cout << "3. ProbeData_TimeAveraged.txt    - Time-averaged probe data" << endl;
cout << "4. ProbeSummary.txt              - List of all probe points" << endl;
cout << "5. CenterlineProfile.txt         - X-direction profile at Y=0" << endl;
cout << "6. VerticalProfile.txt           - Y-direction profile at X=0" << endl;
cout << "7. CurvedDuct_AllFields_Tecplot.dat - Tecplot ASCII file (FETRIANGLE zones)," << endl;
cout << "                                    importable directly into Tecplot, containing" << endl;
cout << "                                    W, Psi (streamline), Zeta (vorticity), Theta" << endl;
cout << "                                    (isotherm), U, V (secondary velocity), Mag," << endl;
cout << "                                    KE, NsTotal, Be as separate contour variables," << endl;
cout << "                                    with one zone per saved time (animatable)." << endl;
cout << "8. CurvedDuct_solution.vtu       - VTK file for visualization (incl. KE, Sgen, Be, Zeta)" << endl;
cout << "9. final_solution_data.txt       - Summary of results" << endl;
cout << "==============================================" << endl;

// ======================================================================
// FINAL PLOTS (one field per window)
// ======================================================================

plot(W,        fill=1, value=1, nbiso=30, wait=0, WindowIndex=0, cmm="Final Axial Velocity W");
plot(Psi,      fill=1, value=1, nbiso=30, wait=0, WindowIndex=1, cmm="Final Stream Function Psi");
plot(Zeta,     fill=1, value=1, nbiso=30, wait=0, WindowIndex=2, cmm="Final Vorticity Zeta");
plot(Theta,    fill=1, value=1, nbiso=30, wait=0, WindowIndex=3, cmm="Final Temperature Theta");
// plot(Mag,      fill=1, value=1, nbiso=30, wait=0, WindowIndex=4, cmm="Final Secondary Flow Magnitude");
// plot(KE,       fill=1, value=1, nbiso=30, wait=0, WindowIndex=5, cmm="Final Kinetic Energy");
// plot(NsTotal,  fill=1, value=1, nbiso=30, wait=0, WindowIndex=6, cmm="Final Total Entropy Generation");
// plot(BeLocal,  fill=1, value=1, nbiso=30, wait=0, WindowIndex=7, cmm="Final Bejan Number");
