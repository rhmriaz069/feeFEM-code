// ======================================================================
// RECTANGULAR CURVED DUCT - WITH 10 STRATEGIC PROBE POINTS
// + KINETIC ENERGY, HYDRAULIC RESISTANCE COEFFICIENT, ENTROPY
//   GENERATION AND BEJAN NUMBER POST-PROCESSING
// GSTU CFD LAB @1 ,BD
// Author : Riaz Hossain, Soykot Deb, Md. Abusaleh Molla,
// Most. Rabita Jahan Puspita,  Muhammad Minarul Islam, 
// ======================================================================
load "iovtk"
load "UMFPACK64"

// ======================================================================
// PARAMETERS
// ======================================================================

real delta = 0.1;
real Dn    = 500.0;
real Gr    = 500.0;
real Pr    = 7.0;

real dt    = 0.005; 
real tmax  = 25.0;   

real tol   = 1.e-6;
real relax = 0.7;
real relaxWall = 0.3;
real Phi = 1.0e-3;

// ======================================================================
// MESH
// ======================================================================

int n = 80;

border b1(t=-1,1){x=t;  y=-1; label=1;} // bottom wall (hot)
border b2(t=-1,1){x=1;  y=t;  label=2;} // outer wall (hot)
border b3(t=1,-1){x=t; y=1;   label=3;} // top wall (cool)
border b4(t=1,-1){x=-1; y=t;  label=4;} // inner wall (cool)

mesh Th = buildmesh(b1(n) + b2(n) + b3(n) + b4(n));
cout << "Mesh created with " << Th.nv << " vertices and " << Th.nt << " triangles" << endl;
real hwall = 2.0/n;   

// ======================================================================
// FE SPACES
// ======================================================================

fespace Vh(Th,P1);

Vh W, Wold, Wk;
Vh Psi, PsiOld, PsiK;
Vh Zeta, ZetaOld, ZetaK;
Vh Theta, ThetaOld, ThetaK;
Vh phi;
Vh U, V, Mag;

// ======================================================================
//  WALL VORTICITY VIA THOM'S FORMULA
// ======================================================================

func real ZetaWallThom(real xx, real yy) {
    real p;
    if (abs(xx+1.0) < 1.0e-6)      { p = PsiOld(xx+hwall, yy); }   // inner wall  x=-1
    else if (abs(xx-1.0) < 1.0e-6) { p = PsiOld(xx-hwall, yy); }   // outer wall  x=+1
    else if (abs(yy+1.0) < 1.0e-6) { p = PsiOld(xx, yy+hwall); }   // bottom wall y=-1
    else                           { p = PsiOld(xx, yy-hwall); }   // top wall    y=+1
    real thomVal = -2.0*p/(hwall*hwall);
    return relaxWall*thomVal + (1.0-relaxWall)*ZetaOld(xx,yy);
}

// --- New post-processing fields ---
Vh KE;        // local kinetic energy field (secondary flow), 0.5*(U^2+V^2)
Vh NsThermal; // local thermal entropy generation number
Vh NsFriction;// local frictional (viscous) entropy generation number
Vh NsTotal;   // local total entropy generation number
Vh BeLocal;   // local Bejan number field

// ======================================================================
// INITIAL CONDITIONS
// ======================================================================

W     = 0.0;
Psi   = 0.0;
Zeta  = 0.0;
Theta = x - y;   // reference sanjeed paper
U     = 0.0;
V     = 0.0;
Mag   = 0.0;
KE    = 0.0;
NsThermal  = 0.0;
NsFriction = 0.0;
NsTotal    = 0.0;
BeLocal    = 0.0;

Wold     = W;
PsiOld   = Psi;
ZetaOld  = Zeta;
ThetaOld = Theta;

// ======================================================================
// 10 STRATEGIC PROBE POINTS DEFINITION
// ======================================================================

int nProbes = 10;

real[int] probeX(10);
real[int] probeY(10);
string[int] probeName(10);
string[int] probeDesc(10);

probeX[0] = -1.0;  probeY[0] =  0.0;  probeName[0] = "P01"; probeDesc[0] = "InnerWall_Center";
probeX[1] = -0.6;  probeY[1] =  0.0;  probeName[1] = "P02"; probeDesc[1] = "Inner_Mid";
probeX[2] =  0.0;  probeY[2] =  0.0;  probeName[2] = "P03"; probeDesc[2] = "Geometric_Center";
probeX[3] =  0.6;  probeY[3] =  0.0;  probeName[3] = "P04"; probeDesc[3] = "Outer_Mid";
probeX[4] =  1.0;  probeY[4] =  0.0;  probeName[4] = "P05"; probeDesc[4] = "OuterWall_Center";
probeX[5] =  0.0;  probeY[5] = -0.6;  probeName[5] = "P06"; probeDesc[5] = "Bottom_Mid";
probeX[6] =  0.0;  probeY[6] =  0.6;  probeName[6] = "P07"; probeDesc[6] = "Top_Mid";
probeX[7] = -0.6;  probeY[7] = -0.6;  probeName[7] = "P08"; probeDesc[7] = "Bottom_Inner_Vortex";
probeX[8] = -0.6;  probeY[8] =  0.6;  probeName[8] = "P09"; probeDesc[8] = "Top_Inner_Vortex";
probeX[9] =  0.6;  probeY[9] = -0.6;  probeName[9] = "P10"; probeDesc[9] = "Bottom_Outer_Vortex";

// Arrays to store probe values
real[int] Wprobe(nProbes);
real[int] Psiprobe(nProbes);
real[int] Thetaprobe(nProbes);
real[int] Uprobe(nProbes);
real[int] Vprobe(nProbes);
real[int] Magprobe(nProbes);
real[int] KEprobe(nProbes);
real[int] NsThermalProbe(nProbes);
real[int] NsFrictionProbe(nProbes);
real[int] NsTotalProbe(nProbes);
real[int] BeProbe(nProbes);

// ======================================================================
// TIME AVERAGING
// ======================================================================

real NuInSum = 0.0;
real NuOutSum = 0.0;
real WmeanSum = 0.0;
real KEtotSum = 0.0;
real lambdaSum = 0.0;
real SgenTotSum = 0.0;
real BeAvgSum = 0.0;
int sampleCount = 0;
real sampleStart = tmax * 0.7;

// Arrays for time-averaged probe data
real[int] WprobeAvg(nProbes);
real[int] PsiprobeAvg(nProbes);
real[int] ThetaprobeAvg(nProbes);
real[int] UprobeAvg(nProbes);
real[int] VprobeAvg(nProbes);
real[int] MagprobeAvg(nProbes);
real[int] KEprobeAvg(nProbes);
real[int] NsTotalProbeAvg(nProbes);
real[int] BeProbeAvg(nProbes);

// Initialize averaging arrays
for(int i=0; i<nProbes; i++) {
    WprobeAvg[i] = 0.0;
    PsiprobeAvg[i] = 0.0;
    ThetaprobeAvg[i] = 0.0;
    UprobeAvg[i] = 0.0;
    VprobeAvg[i] = 0.0;
    MagprobeAvg[i] = 0.0;
    KEprobeAvg[i] = 0.0;
    NsTotalProbeAvg[i] = 0.0;
    BeProbeAvg[i] = 0.0;
}

// ======================================================================
// OUTPUT FILES
// ======================================================================

ofstream timeStepData("TimeStepData.txt");
timeStepData << "# Time Wmax PsiMax SecMax NuIn NuOut NuAvg Lambda Wmean KEtot SgenThermalTot SgenFrictionTot SgenTotal BeAvg TauAxIn TauAxOut TauAxBot TauAxTop TauSecIn TauSecOut TauSecBot TauSecTop" << endl;

// Files for EACH probe point, written separately (10 files total)
// Header includes the probe's fixed X,Y location and description.
ofstream probeFile1("Probe_P01_InnerWall_Center.txt");
probeFile1 << "# Probe P01 InnerWall_Center  X=" << probeX[0] << " Y=" << probeY[0] << endl;
probeFile1 << "# Time W Psi Theta U V Mag KE NsTh NsFr NsTot Be" << endl;

